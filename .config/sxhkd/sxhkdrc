
# --- System Controls ---

# Brightness
XF86MonBrightnessUp
    brightnessctl s +10%

XF86MonBrightnessDown
    brightnessctl s 10%-

# Audio (PulseAudio/Pipewire)
XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle

XF86AudioLowerVolume
    pactl set-sink-volume @DEFAULT_SINK@ -5% && canberra-gtk-play -i audio-volume-change	

XF86AudioRaiseVolume
    pactl set-sink-volume @DEFAULT_SINK@ +5% && canberra-gtk-play -i audio-volume-change

# --- Program Launchers ---

# Terminal emulator
super + Return
    alacritty

# Rofi launchers
alt + Tab
    rofi -show window

super + space
    rofi -show drun

alt + r
    rofi -show run

# Quick Apps
alt + b
    Chromium

alt + f
    pcmanfm

alt + p
    flameshot full --path= ~/Pictures/Screenshots

# Reload sxhkd
super + Escape
    pkill -USR1 -x sxhkd

# --- bspwm Hotkeys ---

# Quit/Restart bspwm 
super + alt + {q,r}
    bspc {quit,wm -r}

# Close and Kill 
super + c
    bspc node -c

super + alt + c
    bspc node -k

# Alternate layouts
super + m
    bspc desktop -l next

# Node manipulation
super + y
    bspc node newest.marked.local -n newest.!automatic.local

super + g
    bspc node -s biggest.window

# --- Window States/Flags ---

# Set window state
super + {t,s,f}
    bspc node -t {tiled,floating,fullscreen}

# Set node flags
super + ctrl + {m,x,y,z}
    bspc node -g {marked,locked,sticky,private}

# --- Focus and Swapping ---

# Focus node in direction
super + {h,j,k,l}
    bspc node -f {west,south,north,east}

# Swap node in direction (Shift -> Alt)
super + alt + {h,j,k,l}
    bspc node -s {west,south,north,east}

# Focus node via path
super + {p,b,comma,period}
    bspc node -f @{parent,brother,first,second}

# Focus next/prev window
super + {_,alt + }w
    bspc node -f {next,prev}.local.!hidden.window

# Focus last node/desktop
super + {grave,Tab}
    bspc {node,desktop} -f last

# Focus history
super + {o,i}
    bspc wm -h off; \
    bspc node {older,newer} -f; \
    bspc wm -h on

# --- Desktop Management ---

# Focus desktop 1-10
super + {1-9,0}
    bspc desktop -f '^{1-9,10}'

# Send node to desktop 1-10 
super + alt + {1-9,0}
    bspc node -d '^{1-9,10}'

# Focus next/previous desktop
super + {bracketright,bracketleft}
    bspc desktop -f {next,prev}.local

# --- Preselection ---

# Preselect direction
super + ctrl + {h,j,k,l}
    bspc node -p {west,south,north,east}

# Preselect ratio
super + ctrl + {1-9}
    bspc node -o 0.{1-9}

# Cancel preselection 
super + ctrl + space
    bspc node -p cancel

super + ctrl + alt + space
    bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

# --- Move/Resize ---

# Expand window (Outward)
super + alt + {Left,Down,Up,Right}
    bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# Contract window (Inward)
super + ctrl + {Left,Down,Up,Right}
    bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# Move floating window
super + {Left,Down,Up,Right}
    bspc node -v {-20 0,0 20,0 -20,20 0}