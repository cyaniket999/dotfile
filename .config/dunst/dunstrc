[global]

   script = ~/.config/dunst/play_sound.sh

    ### Display & Geometry ###
    monitor = 0
    follow = none
    width = (0,300)
    height = (0,100)
    origin = top-right
    offset = (20,60)
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    highlight = "#51afef"
    progress_bar_corner_radius = 4

    ### Appearance ###

    transparency = 0 
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 10
    frame_width = 2
    
    frame_color = "#51afef" 
    separator_color = frame
    sort = yes
    idle_threshold = 0
    corner_radius = 10

    ### Text & Icons ###
    font = JetBrainsMono Nerd Font 10
    line_height = 3
    markup = full
    format = "<span foreground='#51afef' font_weight='bold'>%s</span>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    ### Interaction ###
    mouse_left_click = close_current
    mouse_right_click = close_all

[urgency_low]
    # Deep dark background 
    background = "#1a1b26"
    foreground = "#a9b1d6"
    timeout = 5

[urgency_normal]
    # Dark plum/black background
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#51afef"
    timeout = 10

[urgency_critical]
    background = "#1a1b26"
    foreground = "#f7768e"
    # Red accent for critical, but keeping the dark background
    frame_color = "#f7768e"
    timeout = 0